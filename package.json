{
  "name": "expense",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "bun run src/lib/db/ops/migrate.ts",
    "db:reset": "bun run src/lib/db/ops/reset.ts",
    "db:seed": "bun run src/lib/db/ops/seed.ts",
    "db:data:reset": "bun run src/lib/db/ops/reset-transactions.ts",
    "db:data": "bun run src/lib/db/ops/reset-transactions.ts && bun run src/lib/db/ops/import-transactions-csv.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@tailwindcss/postcss": "^4",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lightningcss": "^1.30.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
